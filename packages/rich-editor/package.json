{
  "name": "@rinsvent/rich-editor",
  "version": "0.1.1",
  "description": "Rich text editor and viewer for React (Lexical-based)",
  "license": "MIT",
  "author": "Rinsvent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rinsvent/rich-editor.git",
    "directory": "packages/rich-editor"
  },
  "homepage": "https://rinsvent.github.io/rich-editor/",
  "bugs": {
    "url": "https://github.com/Rinsvent/rich-editor/issues"
  },
  "keywords": [
    "react",
    "lexical",
    "rich-text",
    "rich-text-editor",
    "wysiwyg",
    "editor",
    "viewer",
    "markdown"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "npx tsup",
    "dev": "npx tsup --watch",
    "lint": "npx tsc --noEmit",
    "test": "npx vitest run",
    "prepublishOnly": "node --input-type=commonjs -e \"require('node:fs').accessSync('dist/index.js')\""
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@lexical/code": "^0.44.0",
    "@lexical/html": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/markdown": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "dompurify": "^3.4.5",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^2.21.0",
    "lexical": "^0.44.0",
    "marked": "^18.0.4"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5",
    "jsdom": "^26.0.0"
  }
}
